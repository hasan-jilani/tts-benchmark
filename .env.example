# TTS Provider Keys (for latency + WER benchmarks)
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_BASE_URL=                          # optional — defaults to wss://api.deepgram.com/v1/speak
ELEVENLABS_API_KEY=your_elevenlabs_api_key
CARTESIA_API_KEY=your_cartesia_api_key
RIME_API_KEY=your_rime_api_key
OPENAI_API_KEY=your_openai_api_key

# WER Benchmark — LLM comparison (required for wer-benchmark.js)
ANTHROPIC_API_KEY=your_anthropic_api_key    # Claude Haiku for pronunciation accuracy evaluation
